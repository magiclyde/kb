DATABASE_URL=postgres://postgres:password@localhost:5432/knowledge_base

# Embedding: 支持 Ollama (本地) 或任意 OpenAI 兼容接口
EMBEDDING_API_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text:v1.5
EMBEDDING_DIM=768

# LLM (用于 RAG 精排回答，可选)
LLM_PROVIDER=ollama
LLM_API_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b

# 服务端口
INDEXER_PORT=3001
SEARCH_PORT=3000

# 缓存配置，可选
CACHE_MAX_SIZE=500
CACHE_TTL_MS=600000

# /api/ask 回答缓存默认复用上面的 CACHE_* 配置。
# 如需单独覆盖回答缓存，再按需添加：
# ASK_CACHE_MAX_SIZE=200
# ASK_CACHE_TTL_MS=600000

# Debug（可选：仅在 DEBUG 时打印分阶段耗时日志）
DEBUG=false
